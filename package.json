{
  "name": "intelligent-virtual-exhibition-platform",
  "private": true,
  "description": "Run API + Next.js together: npm run dev (from repo root). Requires Python on PATH.",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd backend && python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:web": "cd frontend && npm run dev",
    "dev:web-only": "cd frontend && npm run dev",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report",
    "test:admin": "npx playwright test tests/admin/",
    "test:organizer": "npx playwright test tests/organisateur/",
    "test:exhibitor": "npx playwright test tests/exposant/",
    "test:visitor": "npx playwright test tests/visiteur/",
    "test:flows": "npx playwright test tests/flows/",
    "test:specialized": "npx playwright test tests/specialized/",
    "ai": "node tools/ai-orchestrator/index.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "axios": "^1.7.9",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7"
  },
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
